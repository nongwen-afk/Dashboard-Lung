# Local development should use Neon dev branch connection string.
# Production uses Neon main branch connection string via Vercel Production env.
# Never commit .env.local
DATABASE_URL=""

# Must be a real random secret outside example files. Set locally.
BETTER_AUTH_SECRET=""

# Local should be http://localhost:3000
# Production should be Vercel production URL
BETTER_AUTH_URL="http://localhost:3000"
